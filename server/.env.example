# Скопируй в .env и заполни своими значениями: cp .env.example .env

PORT=5000
NODE_ENV=development

# MongoDB connection string (Atlas или локальный)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/music?retryWrites=true&w=majority

# JWT secrets (сгенерируй: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_ACCESS_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_too
JWT_REFRESH_TTL=30d

# CORS (origin клиента)
CLIENT_URL=http://localhost:3000
